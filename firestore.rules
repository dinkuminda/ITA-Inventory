rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserProfile().role == 'Admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidAsset(data) {
      return data.keys().hasAll(['name', 'type', 'status', 'updatedAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.type is string && data.type.size() <= 100 &&
             data.status is string && data.status.size() <= 50 &&
             data.updatedAt is string;
    }

    function isValidLicense(data) {
      return data.keys().hasAll(['name', 'seats', 'usedSeats', 'status', 'updatedAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.seats is int && data.usedSeats is int &&
             data.updatedAt is string;
    }

    // Collection matches
    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAsset(incoming());
      allow update: if isSignedIn() && isValidAsset(incoming()) && (
        isAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedTo', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidLicense(incoming());
      allow update: if isAdmin() && isValidLicense(incoming());
      allow delete: if isAdmin();
    }

    match /maintenance/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
